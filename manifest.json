{
  "manifest_version": 3,
  "name": "LinkedIn Focus",
  "version": "1.1.0",
  "description": "Blocks LinkedIn's endless home feed with a calm, focus-first screen — Messages and Jobs stay fully usable. Includes a daily/weekly save streak and an optional 5-minute unlock for when you genuinely need the feed.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "LinkedIn Focus"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_start"
    }
  ]
}
